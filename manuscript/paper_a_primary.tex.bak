\title{A Geometric-Null Binomial Framework for Harmonic Longitude\\
Proximity Testing in Monument Distributions}

\author{Seth Tenenbaum\thanks{Corresponding author. Email: sethtenenbaum1@gmail.com.
ORCID: \href{https://orcid.org/0009-0008-5797-2498}{0009-0008-5797-2498}.}\\
